{
  "name": "@emoteai/sas-biometric",
  "version": "0.1.1",
  "description": "Thin client SDK for EmoteID biometric SAS attestations on Solana.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntonioCoppe/emoteId-sdk.git"
  },
  "homepage": "https://github.com/AntonioCoppe/emoteId-sdk",
  "bugs": {
    "url": "https://github.com/AntonioCoppe/emoteId-sdk/issues"
  },
  "keywords": [
    "solana",
    "biometric",
    "attestation",
    "sas",
    "wallet",
    "identity",
    "liveness",
    "x402"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run tests"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "sas-lib": "^1.0.10",
    "react": "^19.2.0",
    "tweetnacl": "^1.0.3"
  },
  "peerDependencies": {
    "react-dom": "^19.2.0"
  }
}
